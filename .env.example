# Leucrocotta (inbox agent). GMAIL_USER needs domain-wide delegation on the
# service account (gmail.modify). Without ANTHROPIC_API_KEY it won't draft.
ANTHROPIC_API_KEY=
GMAIL_USER=mayor@mayorclothing.com
NICKEL_SENDER=support@nickel.com

# Social drafting agent. Reuses GOOGLE_SERVICE_ACCOUNT_JSON, ANTHROPIC_API_KEY,
# and RESEND_* above. Without these, /social/poll returns skipped (green by
# design). See PROJECT_STATUS.md for how to create the folders/sheet.
SOCIAL_INBOX_FOLDER_ID=
SOCIAL_QUEUE_SHEET_ID=
SOCIAL_REVIEW_EMAIL=
